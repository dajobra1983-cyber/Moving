<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profi Umzüge & Entrümpelungen</title>
    <style>
        /* Farbpalette und Grundeinstellungen */
        :root {
            --grau: #4A4A4A;
            --dunkelgrau: #2C2C2C;
            --braun: #8B5A2B;
            --rot: #D32F2F;
            --hellgrau: #F9F9F9;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--hellgrau);
            color: var(--dunkelgrau);
            line-height: 1.6;
        }

        /* Navigation */
        header {
            background-color: var(--grau);
            padding: 1rem 5%;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        header h1 {
            color: white;
            font-size: 1.8rem;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        header h1 span {
            color: var(--rot);
        }

        /* Hero Section (Startbereich) */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: linear-gradient(rgba(44, 44, 44, 0.8), rgba(139, 90, 43, 0.7)), url('DEIN_BILD_HIER.jpg') center/cover;
            color: white;
            padding: 0 20px;
            margin-top: 60px;
        }

        .hero h2 {
            font-size: 3rem;
            margin-bottom: 20px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }

        .hero p {
            font-size: 1.2rem;
            margin-bottom: 30px;
        }

        .btn {
            padding: 15px 30px;
            background-color: var(--rot);
            color: white;
            text-decoration: none;
            font-size: 1.2rem;
            border-radius: 5px;
            font-weight: bold;
            transition: all 0.3s ease;
            display: inline-block;
            border: 2px solid var(--rot);
        }

        /* Interaktiver Button Effekt */
        .btn:hover {
            background-color: transparent;
            color: var(--rot);
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(211, 47, 47, 0.3);
        }

        /* Dienstleistungen (Cards) */
        .services {
            padding: 80px 5%;
            text-align: center;
        }

        .services h3 {
            font-size: 2.5rem;
            color: var(--grau);
            margin-bottom: 50px;
        }

        .card-container {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
        }

        .card {
            background-color: white;
            padding: 40px 20px;
            border-radius: 10px;
            width: 300px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            transition: all 0.4s ease;
            border-top: 5px solid var(--braun);
        }

        /* Interaktiver Card Hover Effekt */
        .card:hover {
            transform: translateY(-15px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
            border-top: 5px solid var(--rot);
        }

        .card h4 {
            color: var(--braun);
            font-size: 1.5rem;
            margin-bottom: 15px;
        }

        /* Kontaktbereich */
        .contact {
            background-color: var(--grau);
            color: white;
            padding: 60px 5%;
            text-align: center;
        }

        .contact h3 {
            margin-bottom: 30px;
            font-size: 2rem;
        }

        .contact-info {
            font-size: 1.2rem;
            margin: 10px 0;
            padding: 15px;
            background-color: rgba(255,255,255,0.1);
            display: inline-block;
            border-radius: 5px;
            transition: background 0.3s ease;
        }

        .contact-info:hover {
            background-color: var(--rot);
        }

        /* Scroll-Animations-Klassen */
        .fade-in {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease-out, transform 0.8s ease-out;
        }

        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body>

    <header>
        <h1>Umzüge <span>&</span> Entrümpelungen</h1>
    </header>

    <section class="hero">
        <div class="fade-in">
            <h2>Wir bewegen Ihr Leben.</h2>
            <p>Stressfrei, schnell und zuverlässig. Ihr Partner für Umzüge und besenreine Entrümpelungen.</p>
            <a href="#kontakt" class="btn">Jetzt Angebot einholen</a>
        </div>
    </section>

    <section class="services">
        <h3 class="fade-in">Unsere Leistungen</h3>
        <div class="card-container">
            <div class="card fade-in">
                <h4>Privatumzüge</h4>
                <p>Wir verpacken, transportieren und montieren. Lehnen Sie sich zurück, während wir die schwere Arbeit erledigen.</p>
            </div>
            <div class="card fade-in">
                <h4>Entrümpelungen</h4>
                <p>Vom Keller bis zum Dachboden. Wir entsorgen fachgerecht und hinterlassen alle Räume besenrein.</p>
            </div>
            <div class="card fade-in">
                <h4>Firmenumzüge</h4>
                <p>Effiziente Standortwechsel für Ihr Unternehmen mit minimalen Ausfallzeiten für Ihren Betrieb.</p>
            </div>
        </div>
    </section>

    <section id="kontakt" class="contact">
        <h3 class="fade-in">Bereit für den nächsten Schritt?</h3>
        <p class="fade-in">Kontaktieren Sie uns für eine kostenlose und unverbindliche Besichtigung.</p>
        <br>
        <!-- Hier später deine Daten eintragen -->
        <div class="contact-info fade-in">📞 [DEINE TELEFONNUMMER]</div>
        <div class="contact-info fade-in">✉️ [DEINE E-MAIL ADRESSE]</div>
    </section>

    <script>
        // JavaScript für die Interaktiven Scroll-Effekte (Fade-In)
        document.addEventListener("DOMContentLoaded", function() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, { threshold: 0.1 }); // Löst aus, wenn 10% des Elements sichtbar sind

            const hiddenElements = document.querySelectorAll('.fade-in');
            hiddenElements.forEach((el) => observer.observe(el));
        });
    </script>
</body>
</html>
